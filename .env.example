# Copie para .env e preencha.

# Autenticação Anthropic (usada pelo Jarvis/Haiku e pelo worker/Claude Agent SDK).
ANTHROPIC_API_KEY=

# Repositório em que o worker (coding agent) vai atuar (execução local).
JARVIS_TARGET_REPO=/caminho/para/seu/projeto

# Docker: caminho no HOST do projeto a ser montado em /workspace no container.
# (No container, JARVIS_TARGET_REPO já é /workspace via docker-compose.)
HOST_TARGET_REPO=/caminho/para/seu/projeto

# Opcionais (padrões em jarvis/config.py):
# JARVIS_HOST=127.0.0.1
# JARVIS_PORT=8765
# JARVIS_JARVIS_MODEL=claude-haiku-4-5
# JARVIS_WORKER_MODEL_SIMPLE=claude-sonnet-5
# JARVIS_WORKER_MODEL_COMPLEX=claude-opus-4-8
# JARVIS_WHISPER_MODEL=small
# JARVIS_PIPER_VOICE=pt_BR-faber-medium
